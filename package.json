{
  "name": "deepseek-usage",
  "displayName": "DeepSeek Usage Monitor",
  "description": "Real-time DeepSeek API balance and daily usage monitor in VS Code status bar",
  "version": "0.0.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "deepseek-usage.refresh",
        "title": "DeepSeek Usage: Refresh",
        "category": "DeepSeek"
      }
    ],
    "configuration": {
      "title": "DeepSeek Usage Monitor",
      "properties": {
        "deepseekUsage.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your DeepSeek API Key (starts with sk-)",
          "order": 1
        },
        "deepseekUsage.refreshInterval": {
          "type": "number",
          "default": 5,
          "description": "Refresh interval in minutes (0 to disable auto-refresh)",
          "order": 2
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.118.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
